# Required: AI API key (Z.AI or OpenAI-compatible)
OPENAI_API_KEY=your-api-key-here

# Optional: AI model (default: glm-4.7 via Z.AI)
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
OPENAI_MODEL=glm-4.7

# Required: PostgreSQL database URL for Prisma ORM
# Connection pooling parameters:
# - connection_limit: Maximum number of connections in the pool (default: 10)
# - pool_timeout: Maximum time to wait for a connection (default: 20 seconds)
# - connect_timeout: Maximum time to establish a connection (default: 10 seconds)
DATABASE_URL=postgresql://user:password@host:5432/database?connection_limit=10&pool_timeout=20&connect_timeout=10

# Optional: SQLite DB path (legacy, will be removed in Phase 17)
# DB_PATH=/data/gantt.db

# Optional: Server port (default: 3000, in container Nginx handles :80)
PORT=3000
JWT_SECRET=your-jwt-secret-here

# Optional: SMTP for OTP email delivery
# If EMAIL_HOST is omitted, OTP codes are logged to the server console for development.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-password
EMAIL_FROM="GetGantt <noreply@example.com>"
