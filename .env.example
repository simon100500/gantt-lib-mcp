# Required: AI API key (Z.AI or OpenAI-compatible)
OPENAI_API_KEY=your-api-key-here

# Optional: AI model (default: glm-4.7 via Z.AI)
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
OPENAI_MODEL=glm-4.7

# Required: PostgreSQL database URL for Prisma ORM
# Connection pooling parameters:
# - connection_limit: Maximum number of connections in the pool (default: 10)
# - pool_timeout: Maximum time to wait for a connection (default: 20 seconds)
# - connect_timeout: Maximum time to establish a connection (default: 10 seconds)
DATABASE_URL=postgresql://user:password@host:5432/database?connection_limit=10&pool_timeout=20&connect_timeout=10

# Optional: SQLite DB path (legacy, will be removed in Phase 17)
# DB_PATH=/data/gantt.db

# Optional: Server port (default: 3000, in container Nginx handles :80)
PORT=3000
JWT_SECRET=your-jwt-secret-here

# Optional: comma-separated origins allowed to call public fact APIs.
FACT_CORS_ORIGINS=https://fact.getgantt.ru

# Optional: public Fact app URL used when backend returns foreman day-close links.
FACT_PUBLIC_APP_URL=https://fact.getgantt.ru

# Optional: Fact app URL override used by the main web UI.
# Local example: http://localhost:5175
# VITE_FACT_APP_URL=http://localhost:5175

# Optional: public app URL used by the marketing site for CTA links
# Local example: http://localhost:5173
# Production example: https://ai.getgantt.ru
# PUBLIC_APP_URL=http://localhost:5173

# Optional: landing site URL used by the web admin to open publication pages.
# Local example: http://localhost:4321
# Production example: https://getgantt.ru
# VITE_LANDING_SITE_URL=http://localhost:4321

# Optional: static marketing site build variables for packages/site.
# Important: the site is built as static HTML, so these values must be available
# during `astro build` of the separate site image, not only at runtime.
# PUBLIC_SITE_URL=https://getgantt.ru
# PUBLIC_SITE_PUBLICATIONS_API_BASE_URL=https://ai.getgantt.ru

# Optional: SMTP for OTP email delivery
# If EMAIL_HOST is omitted, OTP codes are logged to the server console for development.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-password
EMAIL_FROM="GetGantt <noreply@example.com>"

# Optional: YooKassa payment provider
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# Optional: Plan limits (defaults in plan-config.ts)
# PLAN_FREE_PROJECTS=1
# PLAN_FREE_AI_GENERATIONS=20
# PLAN_START_PRICE_MONTHLY=1490
# PLAN_START_PRICE_YEARLY=11900
# PLAN_TEAM_PRICE_MONTHLY=4990
# PLAN_TEAM_PRICE_YEARLY=47900
# PLAN_ENTERPRISE_PRICE_MONTHLY=12900
# PLAN_ENTERPRISE_PRICE_YEARLY=129000
