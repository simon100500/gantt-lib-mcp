generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DependencyType {
  FS
  SS
  FF
  SF
}

enum MessageRole {
  user
  assistant
}

enum TaskChangeSource {
  agent
  manual_save
  api
  system
}

enum TaskChangeType {
  create
  update
  soft_delete
  restore
  delete_all
  import
  dependency_create
  dependency_update
  dependency_delete
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  projects     Project[]
  chatsCreated Chat[]      @relation("ChatCreatedBy")
  sessions     Session[]
}

model Project {
  id             String            @id @default(uuid()) @db.Uuid
  ownerId        String            @db.Uuid
  name           String
  tasksRevision  Int               @default(0)
  tasksUpdatedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  deletedById    String?           @db.Uuid

  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  chats          Chat[]
  tasks          Task[]
  shareLinks     ShareLink[]
  sessions       Session[]
  taskEvents     TaskChangeEvent[]

  @@index([ownerId, deletedAt])
  @@index([deletedAt])
}

model Chat {
  id              String      @id @default(uuid()) @db.Uuid
  projectId       String      @db.Uuid
  createdByUserId String?     @db.Uuid
  title           String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  archivedAt      DateTime?
  deletedAt       DateTime?

  project         Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  createdByUser   User?       @relation("ChatCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        Message[]

  @@index([projectId, deletedAt, archivedAt])
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  chatId     String      @db.Uuid
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
  deletedAt DateTime?

  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Restrict)

  @@index([chatId, createdAt])
  @@index([chatId, deletedAt])
}

model Task {
  id             String            @id @default(uuid()) @db.Uuid
  projectId       String            @db.Uuid
  parentTaskId    String?           @db.Uuid
  name            String
  startDate       DateTime          @db.Date
  endDate         DateTime          @db.Date
  color           String?
  progress        Decimal?          @db.Decimal(5, 2)
  sortOrder       Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  deletedById     String?           @db.Uuid

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  parentTask      Task?             @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks      Task[]            @relation("TaskHierarchy")
  predecessorFor  TaskDependency[]  @relation("DependencyPredecessor")
  dependentOn     TaskDependency[]  @relation("DependencyDependent")
  taskEvents      TaskChangeEvent[]

  @@index([projectId, deletedAt, sortOrder])
  @@index([parentTaskId])
  @@index([projectId, deletedAt])
}

model TaskDependency {
  id                String          @id @default(uuid()) @db.Uuid
  projectId          String          @db.Uuid
  dependentTaskId    String          @db.Uuid
  predecessorTaskId  String          @db.Uuid
  type              DependencyType
  lag               Decimal?        @db.Decimal(10, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  project           Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)
  dependentTask     Task            @relation("DependencyDependent", fields: [dependentTaskId], references: [id], onDelete: Restrict)
  predecessorTask   Task            @relation("DependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Restrict)

  @@index([projectId, deletedAt])
  @@index([dependentTaskId, deletedAt])
  @@index([predecessorTaskId, deletedAt])
  // Add a PostgreSQL partial unique index in SQL migration:
  // CREATE UNIQUE INDEX task_dependencies_live_unique
  // ON "TaskDependency" ("dependentTaskId", "predecessorTaskId", "type")
  // WHERE "deletedAt" IS NULL;
}

model TaskChangeEvent {
  id          String          @id @default(uuid()) @db.Uuid
  projectId    String          @db.Uuid
  taskId       String?         @db.Uuid
  runId        String?         @db.Uuid
  sessionId    String?         @db.Uuid
  source       TaskChangeSource
  changeType   TaskChangeType
  createdAt    DateTime        @default(now())
  expiresAt    DateTime

  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([projectId, expiresAt])
  @@index([runId, projectId, createdAt])
}

model Session {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  projectId      String      @db.Uuid
  accessToken   String      @unique
  refreshToken  String      @unique
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model OtpChallenge {
  id          String      @id @default(uuid()) @db.Uuid
  email       String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime    @default(now())

  @@index([email, expiresAt])
}

model ShareLink {
  id         String      @id
  projectId   String      @db.Uuid
  createdAt  DateTime    @default(now())
  revokedAt  DateTime?

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, revokedAt])
}
