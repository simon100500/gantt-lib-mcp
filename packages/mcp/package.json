{
  "name": "@gantt/mcp",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./constraints": "./dist/constraints/index.js",
    "./debug-log": "./dist/debug-log-store.js",
    "./types": "./dist/types.js",
    "./prisma": "./dist/prisma.js",
    "./services": "./dist/services/index.js"
  },
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "start": "node dist/index.js",
    "build:agent": "tsc -p agent/tsconfig.json",
    "test": "node --test src/scheduler.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@prisma/client": "^5.22.0",
    "@qwen-code/sdk": "^0.1.6",
    "@gantt/runtime-core": "^0.1.0",
    "dotenv": "^17.3.1",
    "gantt-lib": "^0.70.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2"
  }
}
