{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@gantt/mcp/constraints": ["src/constraints/index.ts"],
      "@gantt/mcp/debug-log": ["src/debug-log-store.ts"],
      "@gantt/mcp/types": ["src/types.ts"],
      "@gantt/mcp/prisma": ["src/prisma.ts"],
      "@gantt/mcp/services": ["src/services/index.ts"],
      "@gantt/mcp/services/*": ["src/services/*"],
      "@gantt/runtime-core": ["../runtime-core/dist/index.d.ts"],
      "@gantt/runtime-core/types": ["../runtime-core/dist/types.d.ts"],
      "@gantt/runtime-core/prisma": ["../runtime-core/dist/prisma.d.ts"],
      "@gantt/runtime-core/services": ["../runtime-core/dist/services/index.d.ts"],
      "@gantt/runtime-core/services/*": ["../runtime-core/dist/services/*.d.ts"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
