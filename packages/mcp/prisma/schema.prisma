// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../dist/prisma-client"
  binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums for type safety
enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish
}

enum PaymentPeriod {
  monthly
  yearly
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum MessageRole {
  user
  assistant
}

enum GanttDayMode {
  business
  calendar
}

enum ActorType {
  user
  agent
  system
  import_actor
}

// Users table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  projects      Project[]
  sessions      Session[]
  subscriptions Subscription[]
  payments      Payment[]

  @@map("users")
}

// Projects table
model Project {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  name         String
  ganttDayMode GanttDayMode @default(business) @map("gantt_day_mode")
  version      Int         @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      Session[]
  tasks         Task[]
  messages      Message[]
  shareLinks    ShareLink[]
  projectEvents ProjectEvent[]

  @@map("projects")
  @@index([userId])
}

// Sessions table
model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  accessToken  String    @unique @map("access_token")
  refreshToken String    @unique @map("refresh_token")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
  @@index([projectId])
}

// OTP codes table
model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  @@map("otp_codes")
  @@index([email])
}

// Tasks table
model Task {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  color     String?
  progress  Float    @default(0)
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")

  // Relations
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Task?         @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]        @relation("TaskHierarchy")
  dependencies Dependency[] @relation("TaskDependencies")
  dependsOn   Dependency[] @relation("DependsOnTasks")

  @@map("tasks")
  @@index([projectId])
  @@index([parentId])
}

// Dependencies table
model Dependency {
  id         String         @id @default(uuid())
  taskId     String         @map("task_id")
  depTaskId  String         @map("dep_task_id")
  type       DependencyType
  lag        Float         @default(0)

  // Relations
  task    Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  depTask Task @relation("DependsOnTasks", fields: [depTaskId], references: [id], onDelete: Cascade)

  @@map("dependencies")
  @@index([taskId])
  @@index([depTaskId])
}

// Messages table
model Message {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  role      MessageRole
  content   String
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([projectId])
}

// Share links table
model ShareLink {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("share_links")
  @@index([projectId])
}

// Subscriptions table
model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  plan        String   @default("free")
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  aiUsed      Int      @default(0) @map("ai_used")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("subscriptions")
  @@index([userId])
}

// Payments table
model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  plan              String
  period            PaymentPeriod
  amount            Float
  yookassaPaymentId String        @unique @map("yookassa_payment_id")
  status            PaymentStatus @default(pending)
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [userId], references: [userId], map: "payments_subscription_fkey")

  @@map("payments")
  @@index([userId])
}

// Project events table (Phase 36: event log for command history)
model ProjectEvent {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  baseVersion     Int       @map("base_version")
  version         Int
  applied         Boolean   @default(true)
  actorType       ActorType @map("actor_type")
  actorId         String?   @map("actor_id")
  coreVersion     String    @map("core_version")
  command         Json
  result          Json
  patches         Json
  executionTimeMs Int       @map("execution_time_ms")
  createdAt       DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_events")
  @@index([projectId])
  @@index([projectId, version])
}
