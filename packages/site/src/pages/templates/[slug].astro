---
import Layout from "../../layouts/Layout.astro";
import GanttPreview from "../../components/GanttPreview.tsx";
import { TemplateCustomRequestSection } from "../../components/TemplateCustomRequestSection";
import WorkBreakdownAccordion from "../../components/WorkBreakdownAccordion.astro";
import {
  fetchSitePublicationDetail,
  fetchSitePublicationList,
} from "../../lib/publications";
import {
  buildAppTemplateCreateUrl,
  buildSiteUrl,
  getSiteApiOrigin,
} from "../../lib/utils";
import { splitSeoMarkdownSections } from "../../lib/renderSeoMarkdown";

export async function getStaticPaths() {
  const publications = await fetchSitePublicationList("template");
  console.log(
    `[site-build] getStaticPaths templates -> ${publications.length} slug(s): ${publications.map((publication) => publication.slug).join(", ") || "(none)"}`,
  );
  return publications.map((publication) => ({
    params: { slug: publication.slug },
    props: { publication },
  }));
}

const { publication: prefetched } = Astro.props;
const slug = Astro.params.slug ?? "";
const publication =
  (await fetchSitePublicationDetail("template", slug)) ?? prefetched;
console.log(
  `[site-build] Rendering template page ${slug || "(missing-slug)"} -> ${publication?.id ?? "missing-publication"}`,
);
const tasks = publication?.snapshot.tasks ?? [];
const MS_PER_DAY = 86_400_000;
const parseIsoDate = (value: string) => new Date(`${value}T00:00:00`);
const totalDays = tasks.length
  ? Math.max(
      1,
      Math.round(
        (Math.max(
          ...tasks.map((task) => parseIsoDate(task.endDate).getTime()),
        ) -
          Math.min(
            ...tasks.map((task) => parseIsoDate(task.startDate).getTime()),
          )) /
          MS_PER_DAY,
      ) + 1,
    )
  : 0;
const previewTasks = tasks.map((task) => ({
  id: task.id,
  name: task.name,
  startDate: task.startDate,
  endDate: task.endDate,
  parentId: task.parentId,
  type: task.type === "milestone" ? "milestone" as const : "task" as const,
  progress: task.progress ?? 0,
  dependencies: (publication?.snapshot.dependencies ?? [])
    .filter((dependency) => dependency.taskId === task.id)
    .map((dependency) => ({
      taskId: dependency.depTaskId,
      type: dependency.type,
      lag: dependency.lag,
    })),
}));
const createProjectUrl = publication
  ? buildAppTemplateCreateUrl(publication.id)
  : "https://ai.getgantt.ru";
const apiBaseUrl = getSiteApiOrigin();
const seoSections = splitSeoMarkdownSections(publication?.seoBody);
const introSeoHtml = seoSections[0]?.html ?? "";
const templatePath = `/templates/${slug}`;
const templateUrl = buildSiteUrl(templatePath);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "GetGantt",
      item: buildSiteUrl("/"),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Шаблоны проектов",
      item: buildSiteUrl("/templates"),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: publication?.title ?? "Шаблон проекта",
      item: templateUrl,
    },
  ],
};
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: publication?.seoTitle ?? publication?.title ?? "Шаблон проекта — GetGantt",
  url: templateUrl,
  description:
    publication?.seoDescription ??
    publication?.summary ??
    "Публичный шаблон проекта GetGantt",
  isPartOf: {
    "@type": "WebSite",
    name: "GetGantt",
    url: buildSiteUrl("/"),
  },
  about: {
    "@type": "Thing",
    name: publication?.category ?? "Шаблон графика работ",
  },
  mainEntity: {
    "@type": "ItemList",
    name: publication?.title ?? "Состав работ",
    numberOfItems: tasks.length,
  },
};
---

<Layout
  title={publication?.seoTitle ??
    publication?.title ??
    "Шаблон проекта — GetGantt"}
  description={publication?.seoDescription ??
    publication?.summary ??
    "Публичный шаблон проекта GetGantt"}
  pathname={templatePath}
  schema={[breadcrumbSchema, webPageSchema]}
>
  <section>
    <div class="mx-auto max-w-6xl px-4 py-16 lg:py-20">
      <div class="max-w-4xl">
        <div
          class="text-sm font-semibold uppercase tracking-[0.18em] text-primary"
        >
          Шаблон графика работ
        </div>
        <h1
          class="mt-4 text-3xl font-extrabold tracking-tight text-slate-950 lg:text-5xl"
        >
          {publication?.title ?? "Шаблон проекта"}
        </h1>
        {
          publication?.subtitle && (
            <p class="mt-5 max-w-3xl text-xl leading-8 text-slate-600">
              {publication.subtitle}
            </p>
          )
        }
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-700">
          {
            publication?.summary ??
              "Публичный шаблон проекта из publication-базы GetGantt."
          }
        </p>
      </div>

      <div
        class="mt-8 grid gap-4 rounded-[2rem] border border-white/80 bg-white/80 p-5 shadow-[0_18px_60px_rgba(15,23,42,0.08)] backdrop-blur md:grid-cols-3"
      >
        <div>
          <div class="text-xs uppercase tracking-[0.14em] text-slate-500">
            Задач
          </div>
          <div class="mt-2 font-semibold text-slate-900">
            {publication?.taskCount ?? tasks.length}
          </div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.14em] text-slate-500">
            Дней
          </div>
          <div class="mt-2 font-semibold text-slate-900">{totalDays}</div>
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.14em] text-slate-500">
            Категория
          </div>
          <div class="mt-2 font-semibold text-slate-900">
            {publication?.category ?? "Шаблон проекта"}
          </div>
        </div>
      </div>

      <p class="mt-6 max-w-4xl text-base leading-7 text-slate-700">
        Этот шаблон диаграммы Ганта подходит для быстрого старта: вы сразу
        видите состав работ, длительность проекта и структуру этапов, а затем
        можете скопировать шаблон в GetGantt и адаптировать его под свой объект.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={createProjectUrl}
          class="inline-flex items-center justify-center rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
        >
          Открыть в ГетГант
        </a>
        <a
          href="/templates"
          class="inline-flex items-center justify-center rounded-xl border border-primary px-6 py-3 text-sm font-semibold text-primary transition hover:bg-primary/5"
        >
          Все шаблоны
        </a>
      </div>
    </div>
  </section>

  <section class="w-full px-0 py-8 lg:py-10">
    <div class="mx-auto w-full max-w-[1600px] px-3 sm:px-4 lg:px-6">
      <GanttPreview
        client:load
        initialTasks={previewTasks}
        title={publication?.title ?? "Шаблон проекта"}
        fullWidth={true}
        containerHeight="640px"
        headerNote="Чтобы ваши изменения сохранились, сначала скопируйте шаблон в свой кабинет ГетГант"
        headerNoteHref={createProjectUrl}
      />
    </div>
  </section>

  {
    introSeoHtml && (
      <section class="mx-auto max-w-6xl px-4 pb-10 lg:pb-12">
        <div
          class="max-w-none text-slate-700 [&_h2]:mt-0 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:tracking-tight [&_h2]:text-slate-950 [&_h3]:mt-7 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h3]:text-slate-900 [&_p]:mt-4 [&_p]:max-w-4xl [&_p]:text-base [&_p]:leading-8 [&_ul]:mt-4 [&_ul]:space-y-2 [&_ul]:pl-6 [&_li]:list-disc [&_li]:leading-8 [&_strong]:font-semibold [&_strong]:text-slate-950"
          set:html={introSeoHtml}
        />
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 pb-16 lg:pb-24">
    <div>
      <WorkBreakdownAccordion tasks={tasks} title="Состав работ" />
    </div>

      <div class="mt-12 max-w-4xl">
        <h2 class="text-2xl font-bold tracking-tight text-slate-950">
          Как использовать
      </h2>
      <div class="mt-4 space-y-4 text-base leading-8 text-slate-700">
        <p>
          Скопируйте шаблон в свой проект в ГетГант и используйте его как
          готовую основу для планирования работ.
        </p>
        <p>
          После этого можно поправить сроки, убрать или добавить нужные этапы,
          уточнить зависимости между задачами и адаптировать график под свою
          студию, бригаду и темп ремонта.
        </p>
        </div>
      </div>

      <div class="mt-12 max-w-4xl">
        <h2 class="text-2xl font-bold tracking-tight text-slate-950">
          Что есть в шаблоне
        </h2>
        <div class="mt-4 space-y-4 text-base leading-8 text-slate-700">
          <p>
            В шаблоне {publication?.taskCount ?? tasks.length} задач и примерная
            длительность {totalDays} дней. Это удобно для предварительной
            оценки состава работ и обсуждения плана с заказчиком или бригадой.
          </p>
          <p>
            После копирования в GetGantt вы сможете изменить последовательность
            этапов, подвинуть сроки, добавить свои работы и пересчитать связи
            без ручного обновления всего графика.
          </p>
        </div>
      </div>

    {
      publication?.tags?.length ? (
        <div class="mt-12 flex flex-wrap gap-2 border-t border-slate-200 pt-6">
          {publication.tags.map((tag) => (
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-600">
              {tag}
            </span>
          ))}
        </div>
      ) : null
    }
  </section>

  {
    publication?.slug && (
      <TemplateCustomRequestSection
        client:load
        apiBaseUrl={apiBaseUrl}
        templateSlug={publication.slug}
      />
    )
  }
</Layout>
