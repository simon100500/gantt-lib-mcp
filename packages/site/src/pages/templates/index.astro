---
import Layout from "../../layouts/Layout.astro";
import {
  fetchSitePublicationDetail,
  fetchSitePublicationList,
} from "../../lib/publications";
import { buildSiteUrl } from "../../lib/utils";

const publications = await fetchSitePublicationList("template");
const MS_PER_DAY = 86_400_000;
const parseIsoDate = (value: string) => new Date(`${value}T00:00:00`);
const publicationDetails = await Promise.all(
  publications.map(async (publication) => ({
    publication,
    detail: await fetchSitePublicationDetail("template", publication.slug),
  })),
);
const getPublicationDays = (
  detail: Awaited<(typeof publicationDetails)[number]["detail"]>,
) => {
  const snapshotTasks = detail?.snapshot.tasks ?? [];
  if (snapshotTasks.length === 0) {
    return 0;
  }
  return Math.max(
    1,
    Math.round(
      (Math.max(
        ...snapshotTasks.map((task) => parseIsoDate(task.endDate).getTime()),
      ) -
        Math.min(
          ...snapshotTasks.map((task) =>
            parseIsoDate(task.startDate).getTime(),
          ),
        )) /
        MS_PER_DAY,
    ) + 1,
  );
};
const normalizeCategory = (value: string | null) =>
  value?.trim().length ? value.trim() : "Без раздела";
const categoryCounts = publicationDetails.reduce(
  (accumulator, { publication }) => {
    const category = normalizeCategory(publication.category);
    accumulator.set(category, (accumulator.get(category) ?? 0) + 1);
    return accumulator;
  },
  new Map<string, number>(),
);
const categories = Array.from(categoryCounts.entries())
  .sort((left, right) => {
    if (right[1] !== left[1]) {
      return right[1] - left[1];
    }
    return left[0].localeCompare(right[0], "ru");
  });

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Шаблоны проектов GetGantt",
  url: buildSiteUrl("/templates"),
  description:
    "Каталог шаблонов графиков работ, ремонтов и строительных проектов для быстрого старта в GetGantt.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: publicationDetails.map(({ publication, detail }, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: buildSiteUrl(`/templates/${publication.slug}`),
      name: publication.title,
      description:
        publication.summary ?? publication.subtitle ?? "Публичный шаблон проекта",
      additionalProperty: [
        {
          "@type": "PropertyValue",
          name: "taskCount",
          value: publication.taskCount,
        },
        {
          "@type": "PropertyValue",
          name: "durationDays",
          value: getPublicationDays(detail),
        },
      ],
    })),
  },
};
---

<Layout
  title="Шаблоны проектов — GetGantt"
  description="Публичный каталог шаблонов проектов GetGantt для SEO и быстрого старта в продукте."
  pathname="/templates"
  schema={collectionSchema}
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-extrabold text-slate-950">Шаблоны проектов</h1>
    <p class="mt-4 max-w-4xl text-lg leading-8 text-slate-600">
      Скопируйте шаблон в свой проект в ГетГант и используйте его как готовую
      основу для планирования работ
    </p>

    <div class="mt-10 flex flex-wrap gap-3" data-template-filter-controls>
      <button
        type="button"
        class="rounded-full border border-primary bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
        data-template-filter-button
        data-category="all"
        aria-pressed="true"
      >
        Все разделы
      </button>
      {
        categories.map(([category, count]) => (
          <button
            type="button"
            class="rounded-full border border-primary/20 bg-primary/5 px-4 py-2 text-sm font-semibold text-primary transition hover:border-primary/40 hover:bg-primary/10"
            data-template-filter-button
            data-category={category}
            aria-pressed="false"
          >
            {category} ({count})
          </button>
        ))
      }
    </div>

    <div class="mt-4 text-sm text-slate-500" data-template-filter-status>
      Показаны все шаблоны: {publicationDetails.length}
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        publicationDetails.map(({ publication, detail }) => (
          <a
            href={`/templates/${publication.slug}`}
            class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-slate-300 hover:shadow-md"
            data-template-card
            data-category={normalizeCategory(publication.category)}
          >
            <h2 class="font-sans text-lg font-semibold leading-6 text-slate-950">
              {publication.title}
            </h2>
            <div class="mt-4 flex flex-wrap gap-3 text-sm text-slate-500">
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                {normalizeCategory(publication.category)}
              </span>
              <span>{publication.taskCount} задач</span>
              <span>{getPublicationDays(detail)} дней</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  const controls = document.querySelector('[data-template-filter-controls]');
  const status = document.querySelector('[data-template-filter-status]');
  const cards = Array.from(document.querySelectorAll('[data-template-card]'));
  const buttons = Array.from(document.querySelectorAll('[data-template-filter-button]'));

  if (controls && status && cards.length > 0 && buttons.length > 0) {
    const updateFilter = (category) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const matches = category === 'all' || card.dataset.category === category;
        card.toggleAttribute('hidden', !matches);
        if (matches) {
          visibleCount += 1;
        }
      });

      buttons.forEach((button) => {
        const active = button.dataset.category === category;
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        button.classList.toggle('bg-primary', active);
        button.classList.toggle('text-primary-foreground', active);
        button.classList.toggle('border-primary', active);
        button.classList.toggle('bg-primary/5', !active);
        button.classList.toggle('text-primary', !active);
        button.classList.toggle('border-primary/20', !active);
      });

      status.textContent = category === 'all'
        ? `Показаны все шаблоны: ${visibleCount}`
        : `Показан раздел "${category}": ${visibleCount}`;
    };

    controls.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) {
        return;
      }
      const category = target.dataset.category;
      if (!category) {
        return;
      }
      updateFilter(category);
    });
  }
</script>
