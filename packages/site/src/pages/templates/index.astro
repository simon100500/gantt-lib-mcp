---
import Layout from "../../layouts/Layout.astro";
import {
  fetchSitePublicationDetail,
  fetchSitePublicationList,
} from "../../lib/publications";
import { buildSiteUrl } from "../../lib/utils";

const publications = await fetchSitePublicationList("template");
const MS_PER_DAY = 86_400_000;
const parseIsoDate = (value: string) => new Date(`${value}T00:00:00`);
const publicationDetails = await Promise.all(
  publications.map(async (publication) => ({
    publication,
    detail: await fetchSitePublicationDetail("template", publication.slug),
  })),
);
const getPublicationDays = (
  detail: Awaited<(typeof publicationDetails)[number]["detail"]>,
) => {
  const snapshotTasks = detail?.snapshot.tasks ?? [];
  if (snapshotTasks.length === 0) {
    return 0;
  }
  return Math.max(
    1,
    Math.round(
      (Math.max(
        ...snapshotTasks.map((task) => parseIsoDate(task.endDate).getTime()),
      ) -
        Math.min(
          ...snapshotTasks.map((task) =>
            parseIsoDate(task.startDate).getTime(),
          ),
        )) /
        MS_PER_DAY,
    ) + 1,
  );
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Шаблоны проектов GetGantt",
  url: buildSiteUrl("/templates"),
  description:
    "Каталог шаблонов графиков работ, ремонтов и строительных проектов для быстрого старта в GetGantt.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: publicationDetails.map(({ publication, detail }, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: buildSiteUrl(`/templates/${publication.slug}`),
      name: publication.title,
      description:
        publication.summary ?? publication.subtitle ?? "Публичный шаблон проекта",
      additionalProperty: [
        {
          "@type": "PropertyValue",
          name: "taskCount",
          value: publication.taskCount,
        },
        {
          "@type": "PropertyValue",
          name: "durationDays",
          value: getPublicationDays(detail),
        },
      ],
    })),
  },
};
---

<Layout
  title="Шаблоны проектов — GetGantt"
  description="Публичный каталог шаблонов проектов GetGantt для SEO и быстрого старта в продукте."
  pathname="/templates"
  schema={collectionSchema}
>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-extrabold text-slate-950">Шаблоны проектов</h1>
    <p class="mt-4 max-w-4xl text-lg leading-8 text-slate-600">
      Скопируйте шаблон в свой проект в ГетГант и используйте его как готовую
      основу для планирования работ
    </p>
    <p class="mt-4 max-w-4xl text-base leading-7 text-slate-700">
      Здесь собраны шаблоны графиков работ для типовых проектов: от ремонта
      квартиры до строительства дома. Каждая страница показывает структуру
      задач, длительность и состав этапов, чтобы вы могли быстро оценить
      шаблон до копирования в рабочее пространство.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        publicationDetails.map(({ publication, detail }) => (
          <a
            href={`/templates/${publication.slug}`}
            class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
          >
            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
              {publication.category ?? "Template"}
            </div>
            <h2 class="mt-3 text-2xl font-bold text-slate-950">
              {publication.title}
            </h2>
            <p class="mt-3 text-sm leading-6 text-slate-600">
              {publication.summary ??
                publication.subtitle ??
                "Публичный шаблон проекта"}
            </p>
            <div class="mt-4 flex flex-wrap gap-3 text-sm text-slate-500">
              <span>{publication.taskCount} задач</span>
              <span>{getPublicationDays(detail)} дней</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
