---
import Layout from "../../layouts/Layout.astro";
import { fetchSitePublicationDetail, fetchSitePublicationList } from "../../lib/publications";

export async function getStaticPaths() {
  const publications = await fetchSitePublicationList('block');
  return publications.map((publication) => ({
    params: { slug: publication.slug },
    props: { publication },
  }));
}

const { publication: prefetched } = Astro.props;
const slug = Astro.params.slug ?? '';
const publication = await fetchSitePublicationDetail('block', slug) ?? prefetched;
const tasks = publication?.snapshot.tasks ?? [];
---

<Layout
  title={publication?.seoTitle ?? publication?.title ?? "Блок работ — GetGantt"}
  description={publication?.seoDescription ?? publication?.summary ?? "Публичный reusable блок работ GetGantt"}
>
  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Reusable Block</div>
    <h1 class="mt-4 text-4xl font-extrabold text-slate-950">{publication?.title ?? "Блок работ"}</h1>
    {publication?.subtitle && <p class="mt-4 text-xl text-slate-600">{publication.subtitle}</p>}

    <div class="mt-8 grid gap-4 rounded-3xl border border-slate-200 bg-slate-50 p-6 md:grid-cols-3">
      <div>
        <div class="text-xs uppercase tracking-[0.14em] text-slate-500">Категория</div>
        <div class="mt-2 font-semibold text-slate-900">{publication?.category ?? "Не указана"}</div>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.14em] text-slate-500">Отрасль</div>
        <div class="mt-2 font-semibold text-slate-900">{publication?.industry ?? "Не указана"}</div>
      </div>
      <div>
        <div class="text-xs uppercase tracking-[0.14em] text-slate-500">Задач</div>
        <div class="mt-2 font-semibold text-slate-900">{publication?.taskCount ?? tasks.length}</div>
      </div>
    </div>

    <div class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px]">
      <article>
        <p class="text-lg leading-8 text-slate-700">{publication?.summary ?? "Публичный блок работ из общей publication-базы GetGantt."}</p>
        {publication?.seoBody && <div class="prose prose-slate mt-8 max-w-none whitespace-pre-line">{publication.seoBody}</div>}

        <h2 class="mt-12 text-2xl font-bold text-slate-950">Что входит в блок</h2>
        <ol class="mt-4 space-y-3">
          {tasks.map((task) => (
            <li class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-700">
              <span class="font-semibold text-slate-950">{task.name}</span>
              <span class="ml-2 text-sm text-slate-500">{task.startDate} - {task.endDate}</span>
            </li>
          ))}
        </ol>
      </article>

      <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="text-sm font-semibold text-slate-900">CTA</div>
        <p class="mt-3 text-sm leading-6 text-slate-600">Откройте блок в продукте и вставьте его в свой текущий график.</p>
        <a href="https://ai.getgantt.ru" class="mt-6 inline-flex rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
          Открыть в GetGantt
        </a>
      </aside>
    </div>
  </section>
</Layout>
