---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import InputDemo from "../components/InputDemo";
import GanttPreview from "../components/GanttPreview";
---

<Layout title="GetGantt — Из текста в Гант за 30 секунд">
  <main>
    {/* Hero Section */}
    <Hero />

    {/* Demo Section */}
    <div id="demo-section" class="bg-background py-3">
      {/* Gantt Preview Card */}
      <GanttPreview client:load />

      {/* Arrow Down */}
      <div class="my-6 flex justify-center text-muted-foreground animate-bob">
        <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </div>

      {/* Input Demo Card */}
      <InputDemo client:load />
    </div>
  </main>
</Layout>
