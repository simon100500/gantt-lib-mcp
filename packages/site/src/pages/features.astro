---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    id: "ai-chat",
    tag: "AI-ассистент",
    title: "Начинать с чистого листа всегда тяжело. Поэтому не надо.",
    body: "Напишите в чат что нужно сделать — хоть абзац текста, хоть скопируйте бриф. AI разберётся, разобьёт на задачи, расставит сроки и построит диаграмму. А можно начать с пустого графика, если так привычнее.",
    side: "left",
    accent: true,
  },
  {
    id: "interactive-editing",
    tag: "Редактирование",
    title: "Тащите мышью или пишите в чат — как удобнее",
    body: "Перетащили задачу — срок сдвинулся. Растянули — длительность изменилась. Лень целиться? Напишите AI: «перенеси покраску на следующую неделю» или «разбей фундамент на подзадачи» — он сделает. Ну и есть блокировка холста, чтобы случайно ничего не сдвинуть.",
    side: "right",
    accent: false,
  },
  {
    id: "dependencies",
    tag: "Зависимости",
    title: "Сдвинули одну задачу — остальные подстроились",
    body: "Ставьте связи прямо из таблицы: откройте окно связей, найдите задачу поиском, выберите тип — «начать после», «начать вместе», «закончить к началу». Причём можно ставить и предшественника, и последователя. Например, затирка должна прийти к началу укладки плитки — заходите в затирку, ставите связь «Начало-Окончание» в режиме предшественника, выбираете укладку. Всё. При сдвиге сроков вся цепочка пересчитается сама.",
    side: "left",
    accent: false,
  },
  {
    id: "workdays",
    tag: "Рабочие дни",
    title: "Выходные? Какие выходные?",
    body: "Включите режим рабочих дней — и выходные перестанут считаться. Длительность показывается в рабочих днях, а при передвижке задачи сами перескакивают через субботу-воскресенье и растягиваются как надо. Календарь российский, с праздниками.",
    side: "right",
    accent: false,
  },
  {
    id: "search-filters",
    tag: "Поиск и фильтры",
    title: "Нажмите «+» и начните искать. Или сразу добавьте задачу.",
    body: "Строка поиска — многофункциональная. Нажали «+» на клавиатуре — ищете задачи, они подсвечиваются, переходите между ними. Но тут же можно написать новую задачу и нажать Ctrl+Enter — она добавится. А фильтры? Без связей, просроченные, за период — выбирайте.",
    side: "left",
    accent: false,
  },
  {
    id: "hierarchy",
    tag: "Иерархия",
    title: "Вложите подзадачи — получите структуру",
    body: "Любую задачу можно сделать родительской. Вложите в неё подзадачи, чтобы план отражал реальные этапы. Группы сворачиваются — удобно, когда задач за сотню.",
    side: "right",
    accent: false,
  },
  {
    id: "share",
    tag: "Поделиться",
    title: "Отправьте ссылку — и всё, никакой регистрации",
    body: "Создайте ссылку для просмотра и скиньте заказчику или бригадиру. Он откроет и увидит актуальный план. Без регистрации, без паролей, только просмотр.",
    side: "left",
    accent: false,
  },
];
---

<Layout
  title="Возможности GetGantt — AI-планировщик с интерактивным Гантом"
  description="Создавайте диаграммы Ганта из текста, правьте их мышью и автоматически пересчитывайте зависимости. Всё в одном инструменте с AI-ассистентом."
  ogTitle="Возможности GetGantt — AI-планировщик с интерактивным Гантом"
  ogDescription="Создавайте диаграммы Ганта из текста, правьте их мышью и автоматически пересчитывайте зависимости."
>
  {/* Page Hero */}
  <section class="border-b border-border bg-background">
    <div class="container mx-auto px-4 py-20 text-center lg:px-6 lg:py-28">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">
        Возможности
      </p>
      <h1 class="mx-auto max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-foreground lg:text-5xl">
        Напишите что нужно сделать — получите план
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
        AI-ассистент + интерактивная диаграмма Ганта. Опишите проект текстом, а дальше правьте мышью или просто попросите AI. Связи, рабочие дни, фильтры — всё уже есть.
      </p>
      <div class="mt-10">
        <a
          href="https://ai.getgantt.ru/?auth=otp"
          class="btn-gradient-shimmer inline-flex items-center justify-center rounded-xl px-8 py-3.5 text-[15px] font-semibold text-white shadow-lg transition-opacity hover:opacity-90"
        >
          Попробовать бесплатно →
        </a>
      </div>
    </div>
  </section>

  {/* Feature Sections */}
  {features.map((feature) => (
    <section
      id={feature.id}
      class={`border-b border-border ${feature.accent ? "bg-accent/5" : "bg-background"}`}
    >
      <div class="container mx-auto px-4 py-16 lg:px-6 lg:py-24">
        <div
          class={`flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16 ${
            feature.side === "right" ? "lg:flex-row-reverse" : ""
          }`}
        >
          {/* Text Block */}
          <div class="flex-1">
            <span class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
              {feature.tag}
            </span>
            <h2 class="mt-2 text-3xl font-bold leading-tight text-foreground lg:text-4xl">
              {feature.title}
            </h2>
            <p class="mt-4 text-base leading-relaxed text-muted-foreground lg:text-lg">
              {feature.body}
            </p>
          </div>

          {/* Visual Placeholder */}
          <div class="flex-1">
            <div class="aspect-[4/3] rounded-2xl border border-border bg-muted/40 flex items-center justify-center">
              <span class="text-4xl opacity-20">
                {feature.id === "ai-chat" && "🤖"}
                {feature.id === "interactive-editing" && "🖱️"}
                {feature.id === "dependencies" && "🔗"}
                {feature.id === "workdays" && "📅"}
                {feature.id === "search-filters" && "🔍"}
                {feature.id === "hierarchy" && "🗂️"}
                {feature.id === "share" && "🔗"}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* Bottom CTA */}
  <section class="bg-background">
    <div class="container mx-auto px-4 py-20 text-center lg:px-6">
      <h2 class="text-3xl font-bold text-foreground lg:text-4xl">
        Попробуйте — это быстро
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
        Зайдите, напишите что нужно сделать, и через минуту у вас будет план. Без регистрации по паролю — только почта или Telegram.
      </p>
      <div class="mt-8">
        <a
          href="https://ai.getgantt.ru/?auth=otp"
          class="btn-gradient-shimmer inline-flex items-center justify-center rounded-xl px-8 py-3.5 text-[15px] font-semibold text-white shadow-lg transition-opacity hover:opacity-90"
        >
          Открыть GetGantt →
        </a>
      </div>
    </div>
  </section>
</Layout>
