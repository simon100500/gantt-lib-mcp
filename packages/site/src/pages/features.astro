---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    id: "ai-chat",
    tag: "AI-ассистент",
    title: "Опишите проект — получите готовый план",
    body: "Просто напишите, что нужно сделать. AI прочитает ваш текст, разобьёт работу на задачи, расставит сроки и построит диаграмму Ганта. Подходит как для чистого листа, так и для существующего документа или брифа.",
    side: "left",
    accent: true,
  },
  {
    id: "interactive-editing",
    tag: "Интерактивное редактирование",
    title: "Правьте диаграмму мышью или через чат",
    body: "Перетащите задачу — срок сдвинется. Растяните — длительность изменится. Предпочитаете текст? Попросите AI переместить задачу, изменить исполнителя или разбить этап на подзадачи — и диаграмма обновится сразу.",
    side: "right",
    accent: false,
  },
  {
    id: "dependencies",
    tag: "Зависимости и автоматический пересчёт",
    title: "Сдвинули одну задачу — остальные подстроятся",
    body: "Настройте связи между задачами: «начать после», «начать вместе», «закончить до». Когда срок одного этапа меняется, всё, что от него зависит, пересчитывается автоматически. Никаких ручных правок цепочки.",
    side: "left",
    accent: false,
  },
  {
    id: "hierarchy",
    tag: "Иерархия и стадии",
    title: "Группируйте задачи в этапы и стадии",
    body: "Любую задачу можно сделать родительской: вложите в неё подзадачи, чтобы структура плана отражала реальные этапы проекта. Группы можно сворачивать и разворачивать — удобно для больших планов.",
    side: "right",
    accent: false,
  },
  {
    id: "share",
    tag: "Ссылки для просмотра",
    title: "Поделитесь планом одной ссылкой",
    body: "Создайте ссылку для чтения и отправьте заказчику или команде. Получатель видит актуальную диаграмму без возможности редактирования. Никакой регистрации со стороны просматривающего.",
    side: "left",
    accent: false,
  },
];
---

<Layout
  title="Возможности GetGantt — AI-планировщик с интерактивным Гантом"
  description="Создавайте диаграммы Ганта из текста, правьте их мышью и автоматически пересчитывайте зависимости. Всё в одном инструменте с AI-ассистентом."
  ogTitle="Возможности GetGantt — AI-планировщик с интерактивным Гантом"
  ogDescription="Создавайте диаграммы Ганта из текста, правьте их мышью и автоматически пересчитывайте зависимости."
>
  {/* Page Hero */}
  <section class="border-b border-border bg-background">
    <div class="container mx-auto px-4 py-20 text-center lg:px-6 lg:py-28">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">
        Возможности
      </p>
      <h1 class="mx-auto max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-foreground lg:text-5xl">
        Из текста — в рабочий план. Прямо сейчас.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
        GetGantt объединяет AI-ассистента и интерактивный редактор диаграмм Ганта. Опишите проект — получите готовую структуру. Отредактируйте руками или попросите AI — результат обновится сразу.
      </p>
      <div class="mt-10">
        <a
          href="https://ai.getgantt.ru/?auth=otp"
          class="btn-gradient-shimmer inline-flex items-center justify-center rounded-xl px-8 py-3.5 text-[15px] font-semibold text-white shadow-lg transition-opacity hover:opacity-90"
        >
          Попробовать бесплатно →
        </a>
      </div>
    </div>
  </section>

  {/* Feature Sections */}
  {features.map((feature) => (
    <section
      id={feature.id}
      class={`border-b border-border ${feature.accent ? "bg-accent/5" : "bg-background"}`}
    >
      <div class="container mx-auto px-4 py-16 lg:px-6 lg:py-24">
        <div
          class={`flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16 ${
            feature.side === "right" ? "lg:flex-row-reverse" : ""
          }`}
        >
          {/* Text Block */}
          <div class="flex-1">
            <span class="mb-3 inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
              {feature.tag}
            </span>
            <h2 class="mt-2 text-3xl font-bold leading-tight text-foreground lg:text-4xl">
              {feature.title}
            </h2>
            <p class="mt-4 text-base leading-relaxed text-muted-foreground lg:text-lg">
              {feature.body}
            </p>
          </div>

          {/* Visual Placeholder */}
          <div class="flex-1">
            <div class="aspect-[4/3] rounded-2xl border border-border bg-muted/40 flex items-center justify-center">
              <span class="text-4xl opacity-20">
                {feature.id === "ai-chat" && "🤖"}
                {feature.id === "interactive-editing" && "🖱️"}
                {feature.id === "dependencies" && "🔗"}
                {feature.id === "hierarchy" && "🗂️"}
                {feature.id === "share" && "🔗"}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* Bottom CTA */}
  <section class="bg-background">
    <div class="container mx-auto px-4 py-20 text-center lg:px-6">
      <h2 class="text-3xl font-bold text-foreground lg:text-4xl">
        Готовы попробовать?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
        Зайдите в редактор и создайте первый план за несколько минут. Никаких настроек — просто напишите, что нужно сделать.
      </p>
      <div class="mt-8">
        <a
          href="https://ai.getgantt.ru/?auth=otp"
          class="btn-gradient-shimmer inline-flex items-center justify-center rounded-xl px-8 py-3.5 text-[15px] font-semibold text-white shadow-lg transition-opacity hover:opacity-90"
        >
          Открыть GetGantt →
        </a>
      </div>
    </div>
  </section>
</Layout>
