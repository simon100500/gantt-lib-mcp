---
import Layout from "../layouts/Layout.astro";

const productFlow = [
  {
    kicker: "01",
    title: "Текст превращается в структуру проекта",
    body:
      "Вставьте бриф, письмо, ТЗ или просто опишите задачу своими словами. GetGantt собирает этапы, задачи и стартовую логику графика без пустой таблицы.",
  },
  {
    kicker: "02",
    title: "Черновик сразу переходит в рабочий таймлайн",
    body:
      "После генерации вы не зависите от следующего промпта. План открывается в редакторе, где можно двигать задачи, менять длительность и быстро доводить график до реального состояния.",
  },
  {
    kicker: "03",
    title: "Связи и иерархия удерживают план в порядке",
    body:
      "Зависимости, этапы и вложенные блоки помогают не терять логику даже в длинных проектах. Сдвиги становятся читаемыми, а структура остается управляемой.",
  },
];

const featureBands = [
  {
    eyebrow: "AI-first planning",
    title: "Старт без ручного набора задач",
    body:
      "GetGantt ускоряет именно первый шаг: вместо пустого листа вы получаете готовый костяк проекта из исходного текста.",
    points: [
      "Подходит для брифов, писем, ТЗ и свободного описания.",
      "Помогает быстро перевести обсуждение в формальный план.",
    ],
  },
  {
    eyebrow: "Interactive editing",
    title: "Ручной контроль после генерации",
    body:
      "AI не запирает вас внутри чата. Любой срок, этап или задача правятся прямо на диаграмме, как в нормальном рабочем инструменте.",
    points: [
      "Перетаскивание задач и корректировка длительности на таймлайне.",
      "AI ускоряет старт, а не забирает управление.",
    ],
  },
  {
    eyebrow: "Dependencies and hierarchy",
    title: "Сложные планы остаются читаемыми",
    body:
      "Зависимости помогают удерживать логику сроков, а иерархия делает большой проект сканируемым сверху вниз.",
    points: [
      "Связи показывают последствия сдвигов между задачами.",
      "Этапы и подэтапы собирают длинный график в понятную структуру.",
    ],
  },
  {
    eyebrow: "Read-only sharing",
    title: "План легко показать без риска лишних правок",
    body:
      "Для согласования и статуса можно открыть read-only ссылку. Получатель видит актуальный график, но не ломает его случайным редактированием.",
    points: [
      "Подходит для клиентов, руководителей и внешних согласований.",
      "Честный сценарий просмотра без обещаний совместного редактирования.",
    ],
  },
];
---

<Layout
  title="Возможности GetGantt — AI-чат, диаграмма Ганта и зависимости"
  description="Из текста в рабочий план: AI-чат, генерация графика Ганта, ручное редактирование, зависимости, иерархия задач и read-only ссылки."
  ogTitle="Возможности GetGantt"
  ogDescription="Узнайте, как GetGantt превращает текст в диаграмму Ганта и помогает редактировать план вручную без потери структуры."
>
  <section class="feature-hero">
    <div class="feature-hero__mesh" aria-hidden="true"></div>
    <div class="feature-hero__glow feature-hero__glow--left" aria-hidden="true"></div>
    <div class="feature-hero__glow feature-hero__glow--right" aria-hidden="true"></div>
    <div class="feature-shell">
      <div class="feature-hero__content">
        <p class="feature-eyebrow animate-fade-up" style="animation-delay: 80ms;">
          Возможности
        </p>
        <h1 class="feature-hero__title animate-fade-up" style="animation-delay: 140ms;">
          Из исходного текста в управляемый график без отдельного этапа подготовки.
        </h1>
        <p class="feature-hero__body animate-fade-up" style="animation-delay: 200ms;">
          GetGantt начинает с AI-чата, а заканчивает нормальным рабочим
          таймлайном. Вы быстро собираете структуру проекта, удерживаете
          зависимости и вручную доводите план до точного состояния.
        </p>
        <div class="feature-hero__actions animate-fade-up" style="animation-delay: 260ms;">
          <a href="https://ai.getgantt.ru/?auth=otp" class="feature-button feature-button--primary">
            Открыть редактор
          </a>
          <a href="/faq" class="feature-button feature-button--ghost">
            Перейти в FAQ
          </a>
        </div>
      </div>

      <div class="feature-frame animate-fade-up" style="animation-delay: 320ms;">
        <div class="feature-frame__header">
          <span>Input</span>
          <span>AI outline</span>
          <span>Timeline</span>
        </div>
        <div class="feature-frame__lead">
          Создай график запуска продукта: аналитика, дизайн, разработка, QA, релиз
        </div>
        <div class="feature-frame__tracks">
          <div class="feature-frame__row">
            <span>Аналитика</span>
            <div><span style="width: 32%;"></span></div>
          </div>
          <div class="feature-frame__row">
            <span>Дизайн</span>
            <div><span style="width: 44%;"></span></div>
          </div>
          <div class="feature-frame__row">
            <span>Разработка</span>
            <div><span style="width: 74%;"></span></div>
          </div>
          <div class="feature-frame__row">
            <span>QA</span>
            <div><span style="width: 28%;"></span></div>
          </div>
        </div>
        <div class="feature-frame__footer">
          <p>Сначала текст. Потом структура. Потом ручная точность.</p>
          <span>ai.getgantt.ru</span>
        </div>
      </div>
    </div>
  </section>

  <section class="feature-flow">
    <div class="feature-shell">
      <div class="feature-flow__intro">
        <p class="feature-label">Как это работает</p>
        <h2>Один непрерывный маршрут вместо прыжка между чатом, таблицей и графиком.</h2>
      </div>
      <div class="feature-flow__grid">
        {
          productFlow.map((item) => (
            <article class="feature-flow__step">
              <p class="feature-flow__kicker">{item.kicker}</p>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="feature-bands">
    {
      featureBands.map((band) => (
        <div class="feature-band">
          <div class="feature-shell feature-band__shell">
            <div class="feature-band__copy">
              <p class="feature-label">{band.eyebrow}</p>
              <h2>{band.title}</h2>
              <p>{band.body}</p>
              <ul>
                {band.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>
          </div>
        </div>
      ))
    }
  </section>

  <section class="feature-cta">
    <div class="feature-shell">
      <div class="feature-cta__panel">
        <p class="feature-label">GetGantt</p>
        <h2>Быстро собрать. Спокойно уточнить. Показать без лишнего хаоса.</h2>
        <p>
          Если проект уже описан словами, этого достаточно, чтобы начать рабочий
          график. Остальное вы доводите внутри редактора.
        </p>
        <div class="feature-hero__actions">
          <a href="https://ai.getgantt.ru/?auth=otp" class="feature-button feature-button--primary">
            Начать в ai.getgantt.ru
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .feature-shell {
    width: min(900px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .feature-hero {
    position: relative;
    overflow: clip;
    padding: 4.5rem 0 3rem;
    border-bottom: 1px solid hsl(var(--border));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 250, 252, 1) 100%);
  }

  .feature-hero__mesh,
  .feature-hero__glow {
    position: absolute;
    pointer-events: none;
  }

  .feature-hero__mesh {
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.08) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent 92%);
  }

  .feature-hero__glow--left {
    left: -10rem;
    top: 3rem;
    width: 24rem;
    height: 24rem;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12), transparent 70%);
  }

  .feature-hero__glow--right {
    right: -8rem;
    bottom: 0;
    width: 28rem;
    height: 28rem;
    background: radial-gradient(circle, rgba(148, 163, 184, 0.18), transparent 72%);
  }

  .feature-hero .feature-shell {
    position: relative;
    display: grid;
    gap: 2.5rem;
    align-items: end;
  }

  .feature-hero__content {
    max-width: 42rem;
  }

  .feature-eyebrow,
  .feature-label,
  .feature-flow__kicker,
  .feature-frame__header {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }

  .feature-hero__title,
  .feature-flow__intro h2,
  .feature-band__copy h2,
  .feature-cta__panel h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 800;
    color: hsl(var(--foreground));
    text-wrap: balance;
  }

  .feature-hero__body,
  .feature-band__copy p,
  .feature-flow__step p,
  .feature-cta__panel p {
    max-width: 42rem;
    font-size: 1.05rem;
    line-height: 1.85;
    color: hsl(var(--muted-foreground));
  }

  .feature-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .feature-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.3rem;
    padding: 0 1.35rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 700;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .feature-button:hover {
    transform: translateY(-1px);
  }

  .feature-button--primary {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
    box-shadow: 0 18px 40px rgba(99, 102, 241, 0.2);
  }

  .feature-button--ghost {
    border: 1px solid hsl(var(--border));
    background: rgba(255, 255, 255, 0.78);
    color: hsl(var(--foreground));
  }

  .feature-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 1.9rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.94) 100%);
    box-shadow: 0 28px 70px rgba(15, 23, 42, 0.12);
  }

  .feature-frame__header,
  .feature-frame__lead,
  .feature-frame__tracks,
  .feature-frame__footer {
    padding-inline: 1.35rem;
  }

  .feature-frame__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
  }

  .feature-frame__lead {
    padding-top: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: hsl(var(--foreground));
  }

  .feature-frame__tracks {
    display: grid;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .feature-frame__row {
    display: grid;
    grid-template-columns: minmax(0, 9rem) minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    font-size: 0.95rem;
    color: hsl(var(--foreground));
  }

  .feature-frame__row div {
    position: relative;
    height: 2.2rem;
    border-radius: 999px;
    background: rgba(226, 232, 240, 0.82);
    overflow: hidden;
  }

  .feature-frame__row span:last-child,
  .feature-frame__row div span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, hsl(var(--primary)), rgba(99, 102, 241, 0.55));
  }

  .feature-frame__footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 1.25rem;
    border-top: 1px solid rgba(148, 163, 184, 0.16);
    color: hsl(var(--muted-foreground));
    font-size: 0.9rem;
  }

  .feature-flow,
  .feature-cta {
    padding: 4.5rem 0;
  }

  .feature-flow__intro {
    max-width: 52rem;
    margin-bottom: 2.25rem;
  }

  .feature-flow__intro h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-top: 0.75rem;
  }

  .feature-flow__grid {
    display: grid;
    gap: 1px;
    border-top: 1px solid hsl(var(--border));
    border-bottom: 1px solid hsl(var(--border));
    background: hsl(var(--border));
  }

  .feature-flow__step {
    display: grid;
    gap: 0.9rem;
    padding: 1.6rem 0;
    background: hsl(var(--background));
  }

  .feature-flow__step h3 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: hsl(var(--foreground));
  }

  .feature-bands {
    border-top: 1px solid hsl(var(--border));
  }

  .feature-band {
    border-bottom: 1px solid hsl(var(--border));
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(248, 250, 252, 0.86));
  }

  .feature-band__shell {
    display: grid;
    gap: 2rem;
    padding: 2.5rem 0;
    max-width: 680px;
  }

  .feature-band__copy {
    max-width: 48rem;
  }

  .feature-band__copy h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    line-height: 1.2;
    margin-top: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .feature-band__copy ul {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.6rem;
    padding: 0;
    list-style: none;
  }

  .feature-band__copy li {
    position: relative;
    padding-left: 1.15rem;
    font-size: 1rem;
    line-height: 1.75;
    color: hsl(var(--foreground));
  }

  .feature-band__copy li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.8rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: hsl(var(--primary));
  }

  .feature-cta__panel {
    position: relative;
    overflow: hidden;
    padding: 2rem 0 0;
    border-top: 1px solid hsl(var(--border));
  }

  .feature-cta__panel h2 {
    font-size: clamp(2rem, 4vw, 3.9rem);
    margin-top: 0.75rem;
    margin-bottom: 1rem;
    max-width: 54rem;
  }

  @media (min-width: 900px) {
    .feature-hero .feature-shell {
      grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
    }

    .feature-flow__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .feature-flow__step {
      min-height: 16rem;
      padding: 1.75rem 1.25rem 1.75rem 0;
    }

    .feature-flow__step:not(:last-child) {
      border-right: 1px solid hsl(var(--border));
    }
  }

  @media (max-width: 899px) {
    .feature-frame__row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .feature-frame__footer {
      flex-direction: column;
    }
  }
</style>
