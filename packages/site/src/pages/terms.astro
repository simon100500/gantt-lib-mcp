---
import Layout from "../layouts/Layout.astro";

const termsSections = [
  {
    title: "Допустимое использование",
    body:
      "GetGantt предназначен для планирования проектов, работы с задачами, сроками и зависимостями. Не используйте сервис для незаконных сценариев, злоупотребления инфраструктурой или загрузки контента, на который у вас нет прав.",
  },
  {
    title: "Ответственность за планы и исходные данные",
    body:
      "Пользователь сам отвечает за текст, который передает в систему, и за то, как использует получившийся план. AI и редактор помогают ускорить работу, но не заменяют вашу проверку сроков, структуры и проектных решений.",
  },
  {
    title: "Доступность сервиса и изменения",
    body:
      "Мы стараемся поддерживать сервис в рабочем состоянии, но не обещаем непрерывную работу без сбоев, обновлений или временных ограничений. Интерфейсы, поведение AI и состав функций могут меняться по мере развития продукта.",
  },
  {
    title: "Ограничение гарантий",
    body:
      "GetGantt предоставляется как рабочий инструмент для планирования, а не как гарантия точных сроков, оценок или управленческих решений. Перед запуском проекта, согласованием бюджета или передачей плана клиенту результат стоит проверить вручную.",
  },
];
---

<Layout
  title="Условия использования GetGantt"
  description="Какие правила действуют при работе с GetGantt, что остается на ответственности пользователя и как связаться по правовым вопросам."
  ogTitle="Условия использования GetGantt"
  ogDescription="Понятные условия использования сервиса GetGantt: допустимое применение, ответственность пользователя, доступность сервиса и контакт для вопросов."
>
  <section class="legal-hero">
    <div class="legal-shell">
      <div class="legal-hero__meta">
        <p class="legal-label">Terms</p>
        <p class="legal-hero__stamp">GetGantt legal overview</p>
      </div>
      <div class="legal-hero__copy">
        <h1>Условия использования</h1>
        <p>
          Эта страница фиксирует текущие практические правила использования
          сервиса простым языком: где проходит граница допустимого применения,
          что остается на ответственности пользователя и какие ограничения
          нужно учитывать заранее.
        </p>
      </div>
    </div>
  </section>

  <section class="legal-body">
    <div class="legal-shell">
      <div class="legal-grid">
        {
          termsSections.map((section, index) => (
            <article class="legal-row">
              <div class="legal-row__index">{String(index + 1).padStart(2, "0")}</div>
              <div class="legal-row__content">
                <h2>{section.title}</h2>
                <p>{section.body}</p>
              </div>
            </article>
          ))
        }

        <article class="legal-contact">
          <p class="legal-label">Контакт</p>
          <div>
            <h2>Вопросы по support и правовым условиям</h2>
            <p>
              Если у вас есть вопрос по использованию сервиса, ограничениям или
              правовым условиям, напишите на
              <a href="mailto:hello@getgantt.ru">hello@getgantt.ru</a>. Для
              privacy-вопросов используйте также страницу
              <a href="/privacy">/privacy</a>.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .legal-shell {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .legal-label,
  .legal-row__index,
  .legal-hero__stamp {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }

  .legal-hero {
    padding: 4.5rem 0 3rem;
    border-bottom: 1px solid hsl(var(--border));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.94) 100%);
  }

  .legal-hero__meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid hsl(var(--border));
  }

  .legal-hero__copy {
    max-width: 50rem;
    padding-top: 1.25rem;
  }

  .legal-hero h1 {
    font-size: clamp(2.6rem, 5vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    font-weight: 800;
    color: hsl(var(--foreground));
  }

  .legal-hero p {
    margin-top: 1rem;
    font-size: 1.04rem;
    line-height: 1.85;
    color: hsl(var(--muted-foreground));
  }

  .legal-body {
    padding: 3rem 0 5rem;
  }

  .legal-grid {
    display: grid;
    gap: 1px;
    background: hsl(var(--border));
  }

  .legal-row,
  .legal-contact {
    display: grid;
    gap: 1rem;
    padding: 1.4rem 0;
    background: hsl(var(--background));
  }

  .legal-row__content h2,
  .legal-contact h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    font-weight: 700;
    color: hsl(var(--foreground));
  }

  .legal-row__content p,
  .legal-contact p {
    margin-top: 0.8rem;
    max-width: 44rem;
    font-size: 1rem;
    line-height: 1.85;
    color: hsl(var(--muted-foreground));
  }

  .legal-contact a {
    color: hsl(var(--foreground));
    text-decoration: underline;
    text-decoration-color: hsl(var(--border));
    text-underline-offset: 0.22em;
  }

  @media (min-width: 900px) {
    .legal-row,
    .legal-contact {
      grid-template-columns: 6rem minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .legal-contact .legal-label {
      padding-top: 0.45rem;
    }
  }
</style>
