---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Страница не найдена — GetGantt">
  <main class="flex min-h-[calc(100vh-58px)] items-center justify-center">
    <div class="container mx-auto px-4 text-center">
      <div class="mx-auto max-w-md">
        {/* 404 Icon */}
        <div class="mb-8 flex justify-center">
          <div
            class="flex h-24 w-24 items-center justify-center rounded-full bg-muted"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              class="h-12 w-12 stroke-muted-foreground"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
        </div>

        {/* Heading */}
        <h1 class="mb-4 text-4xl font-extrabold text-foreground">
          Страница не найдена
        </h1>

        {/* Body text */}
        <p class="mb-8 text-lg text-muted-foreground">
          Страница, которую вы ищете, не существует или была перемещена.
        </p>

        {/* CTA Button */}
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-3 text-base font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          На главную
        </a>
      </div>
    </div>
  </main>
</Layout>
