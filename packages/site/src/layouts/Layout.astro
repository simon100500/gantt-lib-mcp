---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const defaultTitle = "GetGantt — Из текста в Гант за 30 секунд";
const defaultDescription =
  "Опишите проект своими словами и получите готовый график Ганта с задачами, сроками и зависимостями.";

const {
  title = defaultTitle,
  description = defaultDescription,
  ogTitle,
  ogDescription,
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700;800&subset=cyrillic&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Web Manifest -->
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <Header />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* Import global CSS */
  @import "../styles/global.css";
</style>
