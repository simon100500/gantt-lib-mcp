---
// Footer.astro — 3-column footer with links
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-6">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {/* Product Column */}
      <div>
        <h3 class="mb-4 text-sm font-semibold text-foreground">Продукт</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/features"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Возможности
            </a>
          </li>
          <li>
            <a
              href="/pricing"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Тарифы
            </a>
          </li>
          <li>
            <a
              href="/faq"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              FAQ
            </a>
          </li>
        </ul>
      </div>

      {/* App Column */}
      <div>
        <h3 class="mb-4 text-sm font-semibold text-foreground">Приложение</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="https://ai.getgantt.ru/?auth=otp"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Открыть редактор
            </a>
          </li>
        </ul>
      </div>

      {/* Legal Column */}
      <div>
        <h3 class="mb-4 text-sm font-semibold text-foreground">
          Правовая информация
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/privacy"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Политика конфиденциальности
            </a>
          </li>
          <li>
            <a
              href="/terms"
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              Условия использования
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Copyright */}
    <div
      class="mt-12 border-t border-border pt-8 text-center text-sm text-muted-foreground"
    >
      <p>&copy; 2026 GetGantt. Все права защищены.</p>
    </div>
  </div>
</footer>
