---
type WorkTask = {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  parentId?: string;
};

interface Props {
  node: WorkTask;
  childrenByParent: Map<string, WorkTask[]>;
  depth?: number;
}

const { node, childrenByParent, depth = 0 } = Astro.props;
const children = childrenByParent.get(node.id) ?? [];
const hasChildren = children.length > 0;
const rowPadding = 16 + depth * 18;
---

{hasChildren ? (
  <details class="group" open={depth < 1}>
    <summary
      class={`grid cursor-pointer list-none grid-cols-[minmax(0,1fr)_160px] items-center gap-4 border-b border-slate-100 py-2.5 pr-4 text-left transition-colors hover:bg-slate-50 ${depth === 0 ? 'bg-slate-50/70' : 'bg-transparent'}`}
      style={`padding-left:${rowPadding}px;`}
    >
      <div class="relative min-w-0">
        {depth > 0 && <span class="absolute left-[-12px] top-0 h-full w-px bg-slate-200"></span>}
        <div class="flex items-center gap-2">
          <span class={`${depth === 0 ? 'font-semibold text-slate-950' : 'font-medium text-slate-800'} text-sm`}>{node.name}</span>
        </div>
      </div>
      <div class="text-right text-xs font-medium text-slate-500">
        {node.startDate} - {node.endDate}
      </div>
    </summary>

    <div>
      {children.map((child) => (
        <Astro.self node={child} childrenByParent={childrenByParent} depth={depth + 1} />
      ))}
    </div>
  </details>
) : (
  <div
    class={`grid grid-cols-[minmax(0,1fr)_160px] items-center gap-4 border-b border-slate-100 py-2.5 pr-4 ${depth === 0 ? 'bg-slate-50/70' : 'bg-transparent'}`}
    style={`padding-left:${rowPadding}px;`}
  >
    <div class="relative min-w-0">
      {depth > 0 && <span class="absolute left-[-12px] top-0 h-full w-px bg-slate-200"></span>}
      <span class={`block truncate text-sm ${depth === 0 ? 'font-semibold text-slate-950' : 'text-slate-700'}`}>{node.name}</span>
    </div>
    <div class="text-right text-xs text-slate-500">
      {node.startDate} - {node.endDate}
    </div>
  </div>
)}
