---
type WorkTask = {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  parentId?: string;
};

interface Props {
  node: WorkTask;
  childrenByParent: Map<string, WorkTask[]>;
  depth?: number;
}

const { node, childrenByParent, depth = 0 } = Astro.props;
const children = childrenByParent.get(node.id) ?? [];
const hasChildren = children.length > 0;
const rowPadding = 16 + depth * 18;
const startDate = new Date(`${node.startDate}T00:00:00`);
const endDate = new Date(`${node.endDate}T00:00:00`);
const durationDays = Math.max(1, Math.round((endDate.getTime() - startDate.getTime()) / 86400000) + 1);
---

<style>
  summary.work-breakdown-summary::-webkit-details-marker {
    display: none;
  }

  details[open] > summary .work-breakdown-chevron {
    transform: rotate(90deg);
  }
</style>

{hasChildren ? (
  <details class="group" open={depth < 1}>
    <summary
      class={`work-breakdown-summary grid cursor-pointer list-none grid-cols-[minmax(0,1fr)_120px_120px_84px] items-center gap-4 border-b border-slate-100 py-2.5 pr-4 text-left transition-colors hover:bg-slate-50 ${depth === 0 ? 'bg-slate-50/70' : 'bg-transparent'}`}
      style={`padding-left:${rowPadding}px;`}
    >
      <div class="relative flex min-w-0 items-center gap-2">
        <span class="work-breakdown-chevron flex h-4 w-4 shrink-0 items-center justify-center text-slate-400 transition-transform duration-200 ease-out">
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" aria-hidden="true">
            <path d="M6 3.5 10.5 8 6 12.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
          </svg>
        </span>
        <span class={`${depth === 0 ? 'font-semibold text-slate-950' : 'font-medium text-slate-800'} min-w-0 text-sm`}>{node.name}</span>
      </div>
      <div class="text-right text-xs font-medium tabular-nums text-slate-500">{node.startDate}</div>
      <div class="text-right text-xs font-medium tabular-nums text-slate-500">{node.endDate}</div>
      <div class="text-right text-xs font-medium tabular-nums text-slate-700">{durationDays}</div>
    </summary>

    <div>
      {children.map((child) => (
        <Astro.self node={child} childrenByParent={childrenByParent} depth={depth + 1} />
      ))}
    </div>
  </details>
) : (
  <div
    class={`grid grid-cols-[minmax(0,1fr)_120px_120px_84px] items-center gap-4 border-b border-slate-100 py-2.5 pr-4 ${depth === 0 ? 'bg-slate-50/70' : 'bg-transparent'}`}
    style={`padding-left:${rowPadding}px;`}
  >
    <div class="relative min-w-0">
      <span class={`block truncate text-sm ${depth === 0 ? 'font-semibold text-slate-950' : 'text-slate-700'}`}>{node.name}</span>
    </div>
    <div class="text-right text-xs tabular-nums text-slate-500">{node.startDate}</div>
    <div class="text-right text-xs tabular-nums text-slate-500">{node.endDate}</div>
    <div class="text-right text-xs font-medium tabular-nums text-slate-700">{durationDays}</div>
  </div>
)}
