---
// Hero.astro — Main hero section with rotating value props and CTAs
import RotatingWords from "./RotatingWords";
---

<section
  class="relative mx-auto flex max-w-[900px] flex-col items-center px-4 py-16 text-center md:py-24 lg:py-32"
>
  {/* h1 with rotating words */}
  <h1
    class="mb-8 flex w-full flex-col items-center gap-1 font-extrabold leading-tight text-foreground animate-fade-up"
    style="animation-delay: 70ms; font-family: 'Noto Sans', sans-serif; font-size: clamp(32px, 5.5vw, 56px); letter-spacing: -0.03em;"
  >
    {/* First line: Из [word] в Гант */}
    <div class="flex flex-wrap items-center justify-center gap-4">
      <span>Из</span>

      <RotatingWords
        words={["текста", "сметы", "брифа", "письма", "таблицы"]}
        client:load
      />

      <span>в Гант</span>
    </div>

    {/* Second line */}
    <span class="font-extrabold leading-tight text-foreground"
      >за 30 секунд</span
    >
  </h1>

  {/* Subheading */}
  <p
    class="mb-10 max-w-[520px] text-[17px] leading-relaxed text-secondary-foreground animate-fade-up"
    style="animation-delay: 140ms;"
  >
    Превратите любой текст или документ в <strong
      class="font-semibold text-foreground">готовый график</strong
    >
  </p>

  {/* CTAs */}
  <div
    class="flex flex-wrap justify-center gap-3 animate-fade-up"
    style="animation-delay: 210ms;"
  >
    <a
      href="https://ai.getgantt.ru"
      class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3.5 text-[15px] font-bold text-primary-foreground transition-all hover:opacity-90 hover:shadow-lg hover:-translate-y-0.5"
    >
      Начать бесплатно →
    </a>
    <button
      id="watch-demo-btn"
      class="inline-flex items-center justify-center rounded-xl border border-border bg-card px-8 py-3.5 text-[15px] font-bold text-foreground transition-all hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
    >
      Смотреть демо
    </button>
  </div>
</section>

<script>
  // "Смотреть демо" button scrolls to demo section
  const demoBtn = document.getElementById("watch-demo-btn");
  demoBtn?.addEventListener("click", () => {
    const demoSection = document.getElementById("demo-section");
    demoSection?.scrollIntoView({ behavior: "smooth" });
  });
</script>
