---
// Hero.astro — Main hero section with rotating value props and CTAs
import RotatingWords from "./RotatingWords";
---

<section
  class="relative mx-auto flex max-w-[900px] flex-col items-center px-4 py-12 text-center md:py-16 lg:py-24"
>
  {/* h1 with rotating words */}
  <h1
    class="mb-7 flex w-full flex-col items-center gap-0 font-extrabold leading-none text-foreground animate-fade-up"
    style="animation-delay: 70ms; font-family: 'Noto Sans', sans-serif; font-size: clamp(48px, 7vw, 84px); letter-spacing: -3px;"
  >
    {/* First line: Из [word] — в Гантт */}
    <div class="flex flex-wrap items-center justify-center gap-[18px]">
      <span class="whitespace-nowrap">Из</span>

      <RotatingWords
        words={["текста", "сметы", "брифа", "ТЗ", "письма", "таблицы"]}
        client:load
      />

      <span class="whitespace-nowrap">— в Гант</span>
    </div>

    {/* Second line */}
    <span class="mt-1 block">за 30 секунд</span>
  </h1>

  {/* Subheading */}
  <p
    class="mb-7 max-w-[440px] text-[17px] leading-[1.65] text-secondary-foreground animate-fade-up"
    style="animation-delay: 140ms;"
  >
    Вставьте любой документ или напишите своими словами. Получите <strong
      class="font-bold text-foreground">готовый график</strong
    >, который можно редактировать
  </p>

  {/* CTAs */}
  <div
    class="mb-8 flex flex-wrap justify-center gap-2.5 animate-fade-up"
    style="animation-delay: 210ms;"
  >
    <a
      href="https://ai.getgantt.ru"
      class="inline-flex items-center justify-center rounded-[10px] bg-primary px-7 py-3.5 text-[15px] font-bold text-primary-foreground transition-all hover:opacity-90 hover:shadow-[0_10px_28px_rgba(29,78,216,0.28)] hover:-translate-y-0.5"
    >
      Попробовать бесплатно &rarr;
    </a>
    <button
      id="watch-demo-btn"
      class="inline-flex items-center justify-center rounded-[10px] border border-border bg-card px-7 py-3.5 text-[15px] font-bold text-foreground transition-all hover:bg-border"
    >
      Смотреть демо
    </button>
  </div>
</section>

<script>
  // "Смотреть демо" button scrolls to demo section
  const demoBtn = document.getElementById("watch-demo-btn");
  demoBtn?.addEventListener("click", () => {
    const demoSection = document.getElementById("demo-section");
    demoSection?.scrollIntoView({ behavior: "smooth" });
  });
</script>
