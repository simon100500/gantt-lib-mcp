{
  "name": "@gantt/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node --watch dist/bootstrap.js",
    "dev:watch": "concurrently \"tsc -p tsconfig.json --watch\" \"node --watch dist/bootstrap.js\"",
    "start": "node dist/bootstrap.js"
  },
  "dependencies": {
    "@gantt/mcp": "^0.1.0",
    "@prisma/client": "^6.19.2",
    "@qwen-code/sdk": "^0.1.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.18.0",
    "typescript": "^5.7.2"
  }
}
