// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums for type safety
enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish
}

enum TaskType {
  task
  milestone
}

enum TaskStatus {
  not_started
  in_progress
  done
  closed
}

enum ResourceType {
  human
  equipment
  material
  other
}

enum PaymentPeriod {
  monthly
  yearly
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum MessageRole {
  user
  assistant
}

enum GanttDayMode {
  business
  calendar
}

enum ProjectStatus {
  active
  archived
  deleted
}

enum CalendarScope {
  system
  project
}

enum CalendarDayKind {
  working
  non_working
  shortened
}

enum CalendarDaySource {
  system_seed
  manual
  import
}

enum ActorType {
  user
  agent
  system
  import_actor
}

enum MutationGroupOrigin {
  user_ui
  agent_run
  system
  undo
  redo
}

enum MutationGroupStatus {
  applied
  undone
}

enum BaselineSource {
  current
  history
}

enum BillingState {
  free
  trial_active
  trial_expired
  paid_active
  paid_expired
}

enum TrialSource {
  self_serve
  admin
  promo
}

enum ShareLinkScope {
  project
  task_selection
}

enum TemplateSourceKind {
  project
  task_selection
}

enum TemplatePublicationKind {
  template
  block
}

enum TemplatePublicationStatus {
  draft
  published
  archived
  rejected
}

enum TemplatePublicationVisibility {
  private
  marketplace
  site
  both
}

enum TemplatePublicationVerificationStatus {
  unverified
  reviewed
  verified
  editorial
}

enum TemplateGenerationJobStatus {
  queued
  in_progress
  review_required
  ready_to_publish
  published
  failed
}

enum ProjectGenerationJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum ProjectGenerationJobStage {
  queued
  interpreting
  planning
  compiling
  committing
  finalizing
  succeeded
  failed
}

enum ProjectGenerationPreviewMode {
  none
  ephemeral
  persisted
}

enum ProjectGroupMemberRole {
  editor
  viewer
}

enum ProjectSectionAccess {
  none
  view
  edit
}

enum ProjectGroupInviteStatus {
  pending
  accepted
  revoked
  expired
}

// Users table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  projects        Project[]
  projectCreationIntents ProjectCreationIntent[]
  projectGroups   ProjectGroup[]
  templates       Template[]
  templatePublications TemplatePublication[] @relation("TemplatePublicationSourceUser")
  templateGenerationJobs TemplateGenerationJob[] @relation("TemplateGenerationJobRequestedByUser")
  projectGenerationJobs ProjectGenerationJob[]
  resources       Resource[]
  sessions        Session[]
  subscriptions   Subscription[]
  payments        Payment[]
  usageCounters   UsageCounter[]
  billingEvents   BillingEvent[]
  agentDebugLogs  AgentDebugLog[]
  groupMemberships ProjectGroupMember[] @relation("ProjectGroupMemberUser")
  invitedGroupMembers ProjectGroupMember[] @relation("ProjectGroupMemberInviter")
  sentGroupInvites ProjectGroupInvite[] @relation("ProjectGroupInviteInviter")
  projectViewPreferences ProjectViewPreference[]

  @@map("users")
}

model ProjectGroup {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]
  resources Resource[]
  members   ProjectGroupMember[]
  invites   ProjectGroupInvite[]

  @@map("project_groups")
  @@index([userId])
}

model ProjectGroupMember {
  id              String                 @id @default(uuid())
  groupId         String                 @map("group_id")
  userId          String                 @map("user_id")
  role            ProjectGroupMemberRole
  scheduleAccess  ProjectSectionAccess   @default(edit) @map("schedule_access")
  resourcesAccess ProjectSectionAccess   @default(edit) @map("resources_access")
  financeAccess   ProjectSectionAccess   @default(edit) @map("finance_access")
  invitedByUserId String?                @map("invited_by_user_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  group     ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User         @relation("ProjectGroupMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?        @relation("ProjectGroupMemberInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@map("project_group_members")
  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, role])
}

model ProjectGroupInvite {
  id              String                   @id @default(uuid())
  groupId         String                   @map("group_id")
  email           String
  role            ProjectGroupMemberRole
  scheduleAccess  ProjectSectionAccess     @default(edit) @map("schedule_access")
  resourcesAccess ProjectSectionAccess     @default(edit) @map("resources_access")
  financeAccess   ProjectSectionAccess     @default(edit) @map("finance_access")
  token           String                   @unique
  status          ProjectGroupInviteStatus @default(pending)
  invitedByUserId String?                  @map("invited_by_user_id")
  expiresAt       DateTime                 @map("expires_at")
  acceptedAt      DateTime?                @map("accepted_at")
  revokedAt       DateTime?                @map("revoked_at")
  createdAt       DateTime                 @default(now()) @map("created_at")

  group     ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy User?        @relation("ProjectGroupInviteInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@map("project_group_invites")
  @@index([email])
  @@index([groupId, status])
  @@index([expiresAt])
}

// Projects table
model Project {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  groupId      String       @map("group_id")
  name         String
  status       ProjectStatus @default(active)
  ganttDayMode GanttDayMode @default(business) @map("gantt_day_mode")
  calendarId   String?      @map("calendar_id")
  timelineMarkers Json?     @map("timeline_markers")
  hiddenTaskListColumnsDefault Json? @map("hidden_task_list_columns_default")
  archivedAt   DateTime?    @map("archived_at")
  deletedAt    DateTime?    @map("deleted_at")
  version      Int         @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         ProjectGroup    @relation(fields: [groupId], references: [id], onDelete: Restrict)
  calendar      WorkCalendar?   @relation("ProjectSelectedCalendar", fields: [calendarId], references: [id], onDelete: SetNull)
  ownedCalendars WorkCalendar[] @relation("ProjectOwnedCalendars")
  sessions      Session[]
  tasks          Task[]
  resources      Resource[]
  taskAssignments TaskAssignment[]
  messages       Message[]
  agentSessionState AgentSessionState?
  shareLinks     ShareLink[]
  templatePublications TemplatePublication[] @relation("TemplatePublicationSourceProject")
  templateGenerationJobs TemplateGenerationJob[] @relation("TemplateGenerationJobSourceProject")
  projectGenerationJobs ProjectGenerationJob[]
  projectEvents  ProjectEvent[]
  mutationGroups MutationGroup[]
  baselines      Baseline[]
  agentDebugLogs AgentDebugLog[]
  financeSettings TaskFinanceSetting[]
  fundingEvents   TaskFundingEvent[]
  progressEntries TaskProgressEntry[]
  viewPreferences ProjectViewPreference[]

  @@map("projects")
  @@index([userId])
  @@index([groupId])
  @@index([userId, status])
  @@index([calendarId])
}

model ProjectViewPreference {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  projectId             String   @map("project_id")
  hiddenTaskListColumns Json?    @map("hidden_task_list_columns")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_view_preferences")
  @@unique([userId, projectId])
  @@index([projectId])
}

model MutationGroup {
  id              String              @id @default(uuid())
  projectId       String              @map("project_id")
  baseVersion     Int                 @map("base_version")
  newVersion      Int?                @map("new_version")
  actorType       ActorType           @map("actor_type")
  actorId         String?             @map("actor_id")
  origin          MutationGroupOrigin
  title           String
  status          MutationGroupStatus @default(applied)
  undoable        Boolean             @default(false)
  undoneByGroupId String?             @map("undone_by_group_id")
  redoOfGroupId   String?             @map("redo_of_group_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  ProjectEvent[]

  @@map("mutation_groups")
  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, newVersion(sort: Desc)])
}

model Baseline {
  id                   String         @id @default(uuid())
  projectId            String         @map("project_id")
  name                 String
  source               BaselineSource
  sourceHistoryGroupId String?        @map("source_history_group_id")
  createdAt            DateTime       @default(now()) @map("created_at")

  project      Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        BaselineTask[]
  dependencies BaselineDependency[]

  @@map("baselines")
  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, source])
  @@index([sourceHistoryGroupId])
}

model BaselineTask {
  id          String    @id @default(uuid())
  baselineId  String    @map("baseline_id")
  taskId      String    @map("task_id")
  name        String
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  type        TaskType  @default(task)
  color       String?
  progress    Float     @default(0)
  parentId    String?   @map("parent_id")
  sortOrder   Int       @default(0) @map("sort_order")

  baseline Baseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@map("baseline_tasks")
  @@unique([baselineId, taskId])
  @@index([baselineId, sortOrder])
  @@index([baselineId, parentId])
}

model BaselineDependency {
  id         String         @id @default(uuid())
  baselineId String         @map("baseline_id")
  dependencyId String       @map("dependency_id")
  taskId     String         @map("task_id")
  depTaskId  String         @map("dep_task_id")
  type       DependencyType
  lag        Float          @default(0)

  baseline Baseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@map("baseline_dependencies")
  @@unique([baselineId, dependencyId])
  @@index([baselineId, taskId])
  @@index([baselineId, depTaskId])
}

model WorkCalendar {
  id         String        @id @default(uuid())
  code       String?       @unique
  name       String
  scope      CalendarScope @default(system)
  timezone   String?
  isDefault  Boolean       @default(false) @map("is_default")
  projectId  String?       @map("project_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  project            Project?      @relation("ProjectOwnedCalendars", fields: [projectId], references: [id], onDelete: Cascade)
  selectedByProjects Project[]     @relation("ProjectSelectedCalendar")
  days               CalendarDay[]

  @@map("work_calendars")
  @@index([scope])
  @@index([projectId])
}

model CalendarDay {
  id         String            @id @default(uuid())
  calendarId String            @map("calendar_id")
  date       DateTime
  kind       CalendarDayKind
  label      String?
  source     CalendarDaySource @default(manual)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  calendar WorkCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@map("calendar_days")
  @@unique([calendarId, date])
  @@index([date])
}

// Sessions table
model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  accessToken  String    @unique @map("access_token")
  refreshToken String    @unique @map("refresh_token")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentDebugLogs AgentDebugLog[]

  @@map("sessions")
  @@index([userId])
  @@index([projectId])
}

// OTP codes table
model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  @@map("otp_codes")
  @@index([email])
}

// Tasks table
model Task {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  type      TaskType @default(task)
  status    TaskStatus @default(not_started)
  color     String?
  progress  Float    @default(0)
  workVolume Float?   @map("work_volume")
  workUnit   String?  @map("work_unit")
  completedVolume Float @default(0) @map("completed_volume")
  parentId  String?  @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")

  // Relations
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Task?         @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]        @relation("TaskHierarchy")
  dependencies Dependency[] @relation("TaskDependencies")
  dependsOn   Dependency[] @relation("DependsOnTasks")
  assignments TaskAssignment[]
  financeSetting TaskFinanceSetting?
  fundingEvents  TaskFundingEvent[]
  progressEntries TaskProgressEntry[]

  @@map("tasks")
  @@index([projectId])
  @@index([parentId])
}

model TaskProgressEntry {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  taskId    String   @map("task_id")
  entryDate DateTime @map("entry_date")
  amount    Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_progress_entries")
  @@unique([taskId, entryDate])
  @@index([projectId, taskId])
  @@index([projectId, entryDate])
}

model TaskFinanceSetting {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  taskId      String   @map("task_id")
  plannedCost Decimal  @db.Decimal(18, 2) @map("planned_cost")
  currencyCode String  @default("RUB") @map("currency_code")
  allocationMode String @default("manual") @map("allocation_mode")
  allocationParentTaskId String? @map("allocation_parent_task_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_finance_settings")
  @@unique([taskId])
  @@index([projectId])
  @@index([projectId, allocationParentTaskId])
}

model TaskFundingEvent {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  taskId     String   @map("task_id")
  eventDate DateTime @map("event_date")
  amount    Decimal  @db.Decimal(18, 2)
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_funding_events")
  @@index([projectId, taskId])
  @@index([projectId, eventDate])
}

// Dependencies table
model Dependency {
  id         String         @id @default(uuid())
  taskId     String         @map("task_id")
  depTaskId  String         @map("dep_task_id")
  type       DependencyType
  lag        Float         @default(0)

  // Relations
  task    Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  depTask Task @relation("DependsOnTasks", fields: [depTaskId], references: [id], onDelete: Cascade)

  @@map("dependencies")
  @@index([taskId])
  @@index([depTaskId])
}

model Resource {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  projectId      String?      @map("project_id")
  projectGroupId String?      @map("project_group_id")
  name           String
  type           ResourceType @default(human)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deactivatedAt  DateTime?    @map("deactivated_at")

  // Project-local resources keep projectId. Shared resources have projectId =
  // null and projectGroupId set to the owning group.
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectGroup    ProjectGroup?    @relation(fields: [projectGroupId], references: [id], onDelete: Cascade)
  taskAssignments TaskAssignment[]

  @@map("resources")
  @@index([userId])
  @@index([projectId])
  @@index([projectGroupId])
  @@index([userId, isActive])
  @@index([userId, projectId, isActive])
  @@index([userId, projectGroupId, isActive])
}

model TaskAssignment {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  taskId     String   @map("task_id")
  resourceId String   @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("task_assignments")
  @@unique([taskId, resourceId])
  @@index([projectId, taskId])
  @@index([projectId, resourceId])
}

model Template {
  id          String   @id @default(uuid())
  ownerUserId String   @map("owner_user_id")
  name        String
  sourceKind  TemplateSourceKind @map("source_kind")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner        User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  publications TemplatePublication[] @relation("TemplatePublicationSourceTemplate")
  tasks        TemplateTask[]
  dependencies TemplateDependency[]

  @@map("templates")
  @@index([ownerUserId, updatedAt(sort: Desc)])
}

model TemplateTask {
  id                  String   @id @default(uuid())
  templateId          String   @map("template_id")
  localId             String   @map("local_id")
  name                String
  type                TaskType @default(task)
  color               String?
  parentLocalId       String?  @map("parent_local_id")
  sortOrder           Int      @default(0) @map("sort_order")
  relativeStartOffset Int      @default(0) @map("relative_start_offset")
  durationDays        Int      @default(1) @map("duration_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_tasks")
  @@unique([templateId, localId])
  @@index([templateId, sortOrder])
}

model TemplateDependency {
  id             String         @id @default(uuid())
  templateId     String         @map("template_id")
  sourceLocalId  String         @map("source_local_id")
  targetLocalId  String         @map("target_local_id")
  type           DependencyType
  lag            Float          @default(0)
  createdAt      DateTime       @default(now()) @map("created_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_dependencies")
  @@index([templateId])
  @@index([templateId, sourceLocalId])
  @@index([templateId, targetLocalId])
}

model TemplatePublication {
  id                 String                               @id @default(uuid())
  slug               String                               @unique
  kind               TemplatePublicationKind
  sourceProjectId    String                               @map("source_project_id")
  sourceUserId       String                               @map("source_user_id")
  sourceTemplateId   String?                              @map("source_template_id")
  sourceKind         TemplateSourceKind                   @map("source_kind")
  sourceSelectionTaskIds String[]                         @default([]) @map("source_selection_task_ids")
  title              String
  subtitle           String?
  summary            String?
  category           String?
  industry           String?
  tags               String[]                             @default([])
  status             TemplatePublicationStatus            @default(draft)
  visibility         TemplatePublicationVisibility        @default(private)
  verificationStatus TemplatePublicationVerificationStatus @default(unverified) @map("verification_status")
  seoTitle           String?                              @map("seo_title")
  seoDescription     String?                              @map("seo_description")
  seoBody            String?                              @map("seo_body")
  coverImageUrl      String?                              @map("cover_image_url")
  previewImageUrl    String?                              @map("preview_image_url")
  snapshot           Json
  taskCount          Int                                  @default(0) @map("task_count")
  publishedAt        DateTime?                            @map("published_at")
  archivedAt         DateTime?                            @map("archived_at")
  createdAt          DateTime                             @default(now()) @map("created_at")
  updatedAt          DateTime                             @updatedAt @map("updated_at")

  sourceProject  Project  @relation("TemplatePublicationSourceProject", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  sourceUser     User     @relation("TemplatePublicationSourceUser", fields: [sourceUserId], references: [id], onDelete: Cascade)
  sourceTemplate Template? @relation("TemplatePublicationSourceTemplate", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  generationJobs TemplateGenerationJob[] @relation("TemplateGenerationJobPublication")

  @@map("template_publications")
  @@index([sourceProjectId, updatedAt(sort: Desc)])
  @@index([sourceUserId, updatedAt(sort: Desc)])
  @@index([kind, status, visibility, verificationStatus])
  @@index([status, visibility, verificationStatus, updatedAt(sort: Desc)])
  @@index([category, kind])
  @@index([industry, kind])
}

model TemplateGenerationJob {
  id                 String                      @id @default(uuid())
  requestedByUserId  String                      @map("requested_by_user_id")
  sourceProjectId    String?                     @map("source_project_id")
  publicationId      String?                     @map("publication_id")
  sourceDescription  String                      @map("source_description")
  kind               TemplatePublicationKind
  category           String?
  industry           String?
  title              String?
  slug               String?
  autoPublish        Boolean                     @default(false) @map("auto_publish")
  status             TemplateGenerationJobStatus @default(queued)
  seoTitle           String?                     @map("seo_title")
  seoDescription     String?                     @map("seo_description")
  seoBody            String?                     @map("seo_body")
  errorMessage       String?                     @map("error_message")
  lastRunAt          DateTime?                   @map("last_run_at")
  completedAt        DateTime?                   @map("completed_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  requestedByUser User                 @relation("TemplateGenerationJobRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  sourceProject    Project?            @relation("TemplateGenerationJobSourceProject", fields: [sourceProjectId], references: [id], onDelete: SetNull)
  publication      TemplatePublication? @relation("TemplateGenerationJobPublication", fields: [publicationId], references: [id], onDelete: SetNull)

  @@map("template_generation_jobs")
  @@index([requestedByUserId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([sourceProjectId])
  @@index([publicationId])
}

model ProjectCreationIntent {
  id           String   @id @default(uuid())
  source       String
  text         String
  userId       String?  @map("user_id")
  projectId    String?  @map("project_id")
  requestContextId String? @map("request_context_id")
  historyGroupId String? @map("history_group_id")
  templateSlug String?  @map("template_slug")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  generationJobs ProjectGenerationJob[]

  @@map("project_creation_intents")
  @@index([userId])
  @@index([projectId])
  @@index([templateSlug])
  @@index([expiresAt])
  @@index([consumedAt])
}

model ProjectGenerationJob {
  id               String                       @id @default(uuid())
  projectId        String?                      @map("project_id")
  intentId         String?                      @map("intent_id")
  userId           String                       @map("user_id")
  source           String
  type             String
  status           ProjectGenerationJobStatus   @default(queued)
  stage            ProjectGenerationJobStage    @default(queued)
  statusMessage    String?                      @map("status_message")
  requestContextId String?                      @map("request_context_id")
  historyGroupId   String?                      @map("history_group_id")
  progressPercent  Int?                         @map("progress_percent")
  previewMode      ProjectGenerationPreviewMode @default(none) @map("preview_mode")
  previewAvailable Boolean                      @default(false) @map("preview_available")
  errorCode        String?                      @map("error_code")
  errorMessage     String?                      @map("error_message")
  startedAt        DateTime?                    @map("started_at")
  finishedAt       DateTime?                    @map("finished_at")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")

  project Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  intent  ProjectCreationIntent? @relation(fields: [intentId], references: [id], onDelete: SetNull)
  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("project_generation_jobs")
  @@index([projectId, createdAt(sort: Desc)])
  @@index([intentId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([projectId, status, createdAt(sort: Desc)])
}

// Messages table
model Message {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  role      MessageRole
  content   String
  requestContextId String?   @map("request_context_id")
  historyGroupId   String?   @map("history_group_id")
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, requestContextId])
  @@index([projectId, historyGroupId])
  @@index([projectId, deletedAt])
}

model AgentSessionState {
  id                 String   @id @default(uuid())
  projectId          String   @unique @map("project_id")
  sessionKey         String   @default("project-chat") @map("session_key")
  messagesSnapshot   Json     @map("messages_snapshot")
  rollingSummary     String?  @map("rolling_summary")
  openThreads        Json?    @map("open_threads")
  lastRequestContextId String? @map("last_request_context_id")
  compactionVersion  Int      @default(1) @map("compaction_version")
  schemaVersion      Int      @default(1) @map("schema_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("agent_session_states")
  @@index([updatedAt])
}

// Share links table
model ShareLink {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  label           String         @default("")
  scope           ShareLinkScope @default(project)
  includedTaskIds String[]       @default([]) @map("included_task_ids")
  revokedAt       DateTime?      @map("revoked_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("share_links")
  @@index([projectId])
  @@index([projectId, revokedAt])
}

// Subscriptions table
model Subscription {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  plan        String   @default("free")
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  aiUsed      Int      @default(0) @map("ai_used")
  createdAt   DateTime @default(now()) @map("created_at")

  billingState     BillingState @default(free) @map("billing_state")
  trialPlan        String?      @map("trial_plan")
  trialStartedAt   DateTime?    @map("trial_started_at")
  trialEndsAt      DateTime?    @map("trial_ends_at")
  trialEndedAt     DateTime?    @map("trial_ended_at")
  trialSource      TrialSource? @map("trial_source")
  trialConvertedAt DateTime?    @map("trial_converted_at")
  rolledBackAt     DateTime?    @map("rolled_back_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("subscriptions")
  @@index([userId])
}

model BillingEvent {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  actorType     String   @map("actor_type")
  actorId       String?  @map("actor_id")
  previousState String?  @map("previous_state")
  newState      String   @map("new_state")
  reason        String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_events")
  @@index([userId])
  @@index([createdAt])
}

model UsageCounter {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  limitKey     String   @map("limit_key")
  periodBucket String   @map("period_bucket")
  usage        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage_counters")
  @@unique([userId, limitKey, periodBucket])
  @@index([userId, limitKey])
}

// Payments table
model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  plan              String
  period            PaymentPeriod
  amount            Float
  yookassaPaymentId String        @unique @map("yookassa_payment_id")
  status            PaymentStatus @default(pending)
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [userId], references: [userId], map: "payments_subscription_fkey")

  @@map("payments")
  @@index([userId])
}

// Project events table (Phase 36: event log for command history)
model ProjectEvent {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  clientRequestId String?   @map("client_request_id")
  groupId         String?   @map("group_id")
  baseVersion     Int       @map("base_version")
  version         Int
  ordinal         Int?
  applied         Boolean   @default(true)
  actorType       ActorType @map("actor_type")
  actorId         String?   @map("actor_id")
  coreVersion     String    @map("core_version")
  command         Json
  inverseCommand  Json?     @map("inverse_command")
  result          Json
  patches         Json
  metadata        Json?
  requestContextId String?  @map("request_context_id")
  executionTimeMs Int       @map("execution_time_ms")
  createdAt       DateTime  @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mutationGroup MutationGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("project_events")
  @@index([projectId])
  @@index([projectId, version])
  @@unique([projectId, clientRequestId])
  @@index([groupId, ordinal])
  @@index([requestContextId])
}

model AgentDebugLog {
  id               String    @id @default(uuid())
  source           String
  event            String
  userId           String?   @map("user_id")
  projectId        String?   @map("project_id")
  sessionId        String?   @map("session_id")
  runId            String?   @map("run_id")
  attempt          Int?
  tool             String?
  toolUseId        String?   @map("tool_use_id")
  aiMutationSource String?   @map("ai_mutation_source")
  payload          Json
  createdAt        DateTime  @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("agent_debug_logs")
  @@index([createdAt])
  @@index([source, createdAt])
  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([sessionId, createdAt])
  @@index([runId, attempt, createdAt])
  @@index([tool, createdAt])
}
