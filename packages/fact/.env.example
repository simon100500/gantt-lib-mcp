# Standalone env for the fact frontend build.
# Used by `npm run deploy:fact-caprover` from the repo root.
# The frontend API URL is a Vite build-time value.

VITE_FACT_API_BASE_URL=https://ai.getgantt.ru

FACT_CAPROVER_SERVER=https://captain.example.com
FACT_CAPROVER_APP_NAME=gantt-fact
FACT_CAPROVER_APP_TOKEN=replace-with-gantt-fact-app-token

FACT_DEPLOY_REGISTRY=reg.example.com
FACT_DEPLOY_IMAGE=gantt-fact
