{
  "name": "gantt-lib-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Gantt chart management using gantt-lib",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "build": "npm run build --workspaces",
    "build:mcp": "npm run build -w packages/mcp",
    "build:server": "npm run build -w packages/server",
    "dump:db": "node scripts/dump-db.js",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "dev:site": "npm run dev -w packages/site"
  },
  "keywords": [
    "mcp",
    "gantt",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "patch-package": "^8.0.1",
    "typescript": "^5.7.2"
  }
}
