{
  "name": "gantt-lib-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Gantt chart management using gantt-lib",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package && npm run prisma:generate -w packages/runtime-core",
    "build": "npm run build --workspaces",
    "build:mcp": "npm run build -w packages/mcp",
    "build:server": "npm run build -w packages/server",
    "build:fact": "npm run build -w packages/fact",
    "deploy:image": "node scripts/deploy-image.mjs",
    "deploy:caprover": "node scripts/deploy-image.mjs --deploy-caprover",
    "deploy:fact-image": "node scripts/deploy-image.mjs --target fact",
    "deploy:fact-caprover": "node scripts/deploy-image.mjs --target fact --deploy-caprover",
    "prisma:generate": "npm run prisma:generate -w packages/runtime-core",
    "smoke:template-publications": "node scripts/template-publications-smoke.mjs",
    "eval:agent-e2e": "tsx scripts/agent-e2e-live.ts",
    "eval:agent-e2e:shift-days": "tsx scripts/agent-e2e-live.ts --scenario synthetic-shift-plaster-by-days",
    "test:agent-live-shift-e2e": "tsx --test packages/server/src/agent.live-e2e.test.ts",
    "dump:db": "node scripts/dump-db.js",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "dev:fact": "npm run dev -w packages/fact",
    "dev:site": "npm run dev -w packages/site"
  },
  "keywords": [
    "mcp",
    "gantt",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "patch-package": "^8.0.1",
    "typescript": "^5.7.2"
  }
}
