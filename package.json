{
  "name": "gantt-lib-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Gantt chart management using gantt-lib",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:mcp": "npm run build -w packages/mcp",
    "build:server": "npm run build -w packages/server",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "test": "vitest",
    "test:run": "vitest --run"
  },
  "keywords": [
    "mcp",
    "gantt",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/node": "^22.10.2",
    "@vitest/ui": "^4.0.18",
    "pg": "^8.20.0",
    "prisma": "^6.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
